type ResultStatus = 
 variant {
   Active;
   Expired;
   Loss;
   Win;
 };
type Result = 
 variant {
   err: text;
   ok;
 };
type ResponseRating = 
 record {
   messageId: text;
   rating: int;
   timestamp: int;
 };
type PushNotification = 
 record {
   active: bool;
   body: text;
   createdAt: int;
   expiresAt: opt int;
   id: text;
   title: text;
 };
type PriceData = 
 record {
   asset: text;
   price: float64;
   priceChange24h: float64;
   trend: text;
   updatedAt: int;
 };
type NotifyMe = 
 record {
   contact: text;
   dateSubmitted: text;
   id: text;
   name: opt text;
 };
type MarketType = 
 variant {
   Crypto;
   Forex;
   Stock;
 };
type MarketSentiment = 
 record {
   assets: vec AssetSentiment;
   overall: SentimentLevel;
   updatedAt: int;
 };
type MarketMoodBanner = 
 record {
   active: bool;
   message: text;
   mood: text;
   updatedAt: int;
 };
type MarketCount = 
 record {
   count: nat;
   market: text;
 };
type MaintenanceMode = 
 record {
   enabled: bool;
   message: text;
   updatedAt: int;
 };
type JournalEntry = 
 record {
   asset: text;
   direction: text;
   entryPrice: float64;
   exitPrice: opt float64;
   id: text;
   lots: float64;
   notes: text;
   pnl: opt float64;
   timestamp: int;
 };
type HypeMilestone = 
 record {
   achieved: bool;
   achievedAt: opt int;
   id: text;
   order: nat;
   targetCount: nat;
   title: text;
 };
type HolderBenefit = 
 record {
   active: bool;
   description: text;
   icon: text;
   id: text;
   title: text;
 };
type FaqCategory = 
 variant {
   DmnzToken;
   GeneralTrading;
   Platform;
   Signals;
 };
type FAQ = 
 record {
   answer: text;
   category: FaqCategory;
   helpfulCount: nat;
   id: text;
   notHelpfulCount: nat;
   order: nat;
   question: text;
   timestamp: int;
 };
type Direction = 
 variant {
   Buy;
   Sell;
 };
type DemonZenoQuote = 
 record {
   active: bool;
   author: text;
   id: text;
   quote: text;
 };
type DayStats = 
 record {
   day: text;
   losses: nat;
   wins: nat;
 };
type DateCount = 
 record {
   count: nat;
   date: text;
 };
type Confidence = 
 variant {
   High;
   Low;
   Medium;
 };
type CommunityQuestion = 
 record {
   answer: opt text;
   id: text;
   isActive: bool;
   isPinned: bool;
   question: text;
   timestamp: int;
   votes: nat;
 };
type CommunityMilestone = 
 record {
   celebrateUntil: opt int;
   description: text;
   id: text;
   reached: bool;
   reachedAt: opt int;
   title: text;
 };
type CommunityCounter = 
 record {
   binanceCount: nat;
   lastUpdated: int;
   twitterCount: nat;
 };
type ChatMessage = 
 record {
   content: text;
   provider: opt text;
   role: text;
   timestamp: int;
 };
type BurnTracker = 
 record {
   lastUpdated: int;
   totalBurned: nat;
 };
type BurnScheduleEntry = 
 record {
   amount: text;
   date: text;
   id: text;
   reason: text;
   status: text;
   txHash: opt text;
 };
type BurnEvent = 
 record {
   amount: text;
   createdAt: int;
   date: text;
   executed: bool;
   id: text;
   reason: text;
 };
type BinancePost = 
 record {
   date: text;
   id: text;
   snippet: text;
   title: text;
   url: text;
 };
type AuditSnapshot = 
 record {
   createdAt: int;
   dataHash: text;
   id: text;
   snapshotLabel: text;
 };
type AuditEntry = 
 record {
   action: text;
   adminToken: text;
   details: text;
   id: text;
   rollbackData: opt text;
   timestamp: int;
 };
type AssetStats = 
 record {
   asset: text;
   losses: nat;
   wins: nat;
 };
type AssetSentiment = 
 record {
   asset: text;
   lastPriceUpdate: int;
   level: SentimentLevel;
   market: text;
   note: text;
   price: float64;
   priceChange24h: float64;
   trend: text;
   updatedAt: int;
 };
type AnnouncementCategory = 
 variant {
   Admin;
   Alert;
   General;
   Signal;
   Token;
 };
type Announcement = 
 record {
   body: text;
   category: AnnouncementCategory;
   id: text;
   isActive: bool;
   isPinned: bool;
   link: opt text;
   publishAt: opt int;
   timestamp: int;
   title: text;
 };
type Analytics = 
 record {
   notifyMeByDate: vec DateCount;
   signalsByMarket: vec MarketCount;
   totalNotifyMe: nat;
 };
type ActivityEntry = 
 record {
   count: nat;
   dayOfWeek: nat;
   hour: nat;
 };
type AbTest = 
 record {
   active: bool;
   id: text;
   impressionsA: nat;
   impressionsB: nat;
   name: text;
   variantA: text;
   variantB: text;
 };
