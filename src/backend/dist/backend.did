type WhitepaperSection = 
 record {
   content: text;
   title: text;
 };
type WhitepaperContent = 
 record {
   sections: vec WhitepaperSection;
   title: text;
   updatedAt: int;
 };
type TopTrader = 
 record {
   achievement: text;
   bio: text;
   createdAt: int;
   id: text;
   isActive: bool;
   name: text;
   week: text;
 };
type TokenData = 
 record {
   burnedAmount: text;
   launchDate: text;
   launchPlatform: text;
   name: text;
   supply: text;
   ticker: text;
 };
type Timeframe = 
 variant {
   LongTerm;
   Scalp;
   Swing;
 };
type Testimonial = 
 record {
   active: bool;
   asset: opt text;
   content: text;
   createdAt: int;
   id: text;
   name: text;
   winAmount: opt text;
 };
type StatsConfig = 
 record {
   manualStats: opt Stats;
   useManual: bool;
 };
type Stats = 
 record {
   active: nat;
   assetsCovered: nat;
   losses: nat;
   totalSignals: nat;
   winRate: float64;
   wins: nat;
 };
type SignalTemplate = 
 record {
   asset: text;
   confidence: Confidence;
   createdAt: int;
   direction: Direction;
   id: text;
   marketType: MarketType;
   name: text;
   notes: text;
   timeframe: Timeframe;
 };
type SignalPerformanceStats = 
 record {
   losses: nat;
   pending: nat;
   topAssets: vec AssetStats;
   totalSignals: nat;
   weeklyTrend: vec DayStats;
   winRate: float64;
   wins: nat;
 };
type SignalOfWeekFull = 
 record {
   comment: text;
   featuredAt: int;
   signal: Signal;
   weekOf: text;
 };
type SignalInput = 
 record {
   asset: text;
   confidence: Confidence;
   direction: Direction;
   entryPrice: text;
   expiry: opt int;
   isDraft: bool;
   marketType: MarketType;
   notes: text;
   providerLabel: text;
   publishAt: opt int;
   sourceLabel: text;
   stopLoss: text;
   tags: vec text;
   targetPrice: text;
   templateId: opt text;
   timeframe: Timeframe;
   tp1: text;
   tp2: text;
   tp3: text;
 };
type Signal = 
 record {
   asset: text;
   confidence: Confidence;
   datePosted: text;
   direction: Direction;
   entryPrice: text;
   expiry: opt int;
   id: text;
   isDraft: bool;
   marketType: MarketType;
   notes: text;
   providerLabel: text;
   publishAt: opt int;
   result: ResultStatus;
   sourceLabel: text;
   stopLoss: text;
   tags: vec text;
   targetPrice: text;
   templateId: opt text;
   timeframe: Timeframe;
   tp1: text;
   tp2: text;
   tp3: text;
   voteDown: nat;
   voteUp: nat;
 };
type SentimentLevel = 
 variant {
   Bearish;
   Bullish;
   Neutral;
 };
type RoadmapMilestone = 
 record {
   completed: bool;
   description: text;
   title: text;
   year: text;
 };
